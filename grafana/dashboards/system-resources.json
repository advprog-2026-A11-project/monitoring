        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "avg(disk_free_bytes{service_name=\"$application\",instance=~\"$instance\"})",
          "legendFormat": "free"
        },
        {
          "refId": "B",
          "expr": "avg(disk_total_bytes{service_name=\"$application\",instance=~\"$instance\"})",
          "legendFormat": "total"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        },
        "overrides": []
      }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "HikariCP Connections",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 20
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(hikaricp_connections_active{service_name=\"$application\",instance=~\"$instance\"})",
          "legendFormat": "active"
        },
        {
          "refId": "B",
          "expr": "sum(hikaricp_connections_idle{service_name=\"$application\",instance=~\"$instance\"})",
          "legendFormat": "idle"
        },
        {
          "refId": "C",
          "expr": "sum(hikaricp_connections_pending{service_name=\"$application\",instance=~\"$instance\"})",
          "legendFormat": "pending"
        },
        {
          "refId": "D",
          "expr": "sum(hikaricp_connections_max{service_name=\"$application\",instance=~\"$instance\"})",
          "legendFormat": "max"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none"
        },
        "overrides": []
      }
    }
  ]
}