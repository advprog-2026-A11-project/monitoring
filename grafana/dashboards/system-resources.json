{
  "id": null,
  "uid": "system-resources",
  "title": "system-resources",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "15s",
  "timezone": "browser",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "application",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "PBFA97CFB590B2093"
        },
        "query": "label_values(service_name)",
        "definition": "label_values(service_name)",
        "refresh": 1,
        "multi": false,
        "includeAll": false
      },
      {
        "name": "instance",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "PBFA97CFB590B2093"
        },
        "query": "label_values(jvm_memory_used_bytes{service_name=\"$application\"}, instance)",
        "definition": "label_values(jvm_memory_used_bytes{service_name=\"$application\"}, instance)",
        "refresh": 1,
        "multi": true,
        "includeAll": true,
        "allValue": ".*"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Process CPU",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "avg(process_cpu_usage{service_name=\"$application\",instance=~\"$instance\"})"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit"
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "System CPU",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "avg(system_cpu_usage{service_name=\"$application\",instance=~\"$instance\"})"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit"
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Open FDs",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "avg(process_files_open{service_name=\"$application\",instance=~\"$instance\"})"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none"
        },
        "overrides": []
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "FD Limit",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "avg(process_files_max{service_name=\"$application\",instance=~\"$instance\"})"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none"
        },
        "overrides": []
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "RAM: JVM Heap",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(jvm_memory_used_bytes{service_name=\"$application\",instance=~\"$instance\",area=\"heap\"})",
          "legendFormat": "used"
        },
        {
          "refId": "B",
          "expr": "sum(jvm_memory_committed_bytes{service_name=\"$application\",instance=~\"$instance\",area=\"heap\"})",
          "legendFormat": "committed"
        },
        {
          "refId": "C",
          "expr": "sum(jvm_memory_max_bytes{service_name=\"$application\",instance=~\"$instance\",area=\"heap\"})",
          "legendFormat": "max"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        },
        "overrides": []
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "RAM: JVM Non-Heap + Buffers",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(jvm_memory_used_bytes{service_name=\"$application\",instance=~\"$instance\",area=\"nonheap\"})",
          "legendFormat": "nonheap used"
        },
        {
          "refId": "B",
          "expr": "sum(jvm_buffer_memory_used_bytes{service_name=\"$application\",instance=~\"$instance\"})",
          "legendFormat": "buffer used"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        },
        "overrides": []
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Heap Utilization %",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 12
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "100 * sum(jvm_memory_used_bytes{service_name=\"$application\",instance=~\"$instance\",area=\"heap\"}) / sum(jvm_memory_max_bytes{service_name=\"$application\",instance=~\"$instance\",area=\"heap\"})",
          "legendFormat": "heap %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent"
        },
        "overrides": []
      }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "GC Pause (avg seconds)",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 12
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(jvm_gc_pause_milliseconds_sum{service_name=\"$application\",instance=~\"$instance\"}[5m]) / rate(jvm_gc_pause_milliseconds_count{service_name=\"$application\",instance=~\"$instance\"}[5m]) / 1000"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Threads",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 12
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "avg(jvm_threads_live{service_name=\"$application\",instance=~\"$instance\"})",
          "legendFormat": "live"
        },
        {
          "refId": "B",
          "expr": "avg(jvm_threads_daemon{service_name=\"$application\",instance=~\"$instance\"})",
          "legendFormat": "daemon"
        },
        {
          "refId": "C",
          "expr": "avg(jvm_threads_peak{service_name=\"$application\",instance=~\"$instance\"})",
          "legendFormat": "peak"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none"
        },
        "overrides": []
      }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Disk Space",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
