{
  "id": null,
  "uid": "forum-monitoring",
  "title": "Forum Monitoring",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "timezone": "browser",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "query": "prometheus",
        "current": {}
      },
      {
        "name": "DS_LOKI",
        "type": "datasource",
        "query": "loki",
        "current": {}
      },
      {
        "name": "application",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "query": "label_values(forum_messages_fetched_total, service_name)",
        "definition": "label_values(forum_messages_fetched_total, service_name)",
        "refresh": 1,
        "multi": false,
        "includeAll": false,
        "current": {
          "text": "be-forum",
          "value": "be-forum"
        }
      },
      {
        "name": "instance",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "query": "label_values(forum_messages_fetched_total{service_name=\"$application\"}, instance)",
        "definition": "label_values(forum_messages_fetched_total{service_name=\"$application\"}, instance)",
        "refresh": 1,
        "multi": true,
        "includeAll": true,
        "allValue": ".*"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Messages Created (count)",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "refId": "A",
          "expr": "round(sum(increase(forum_messages_created_total{service_name=\"$application\"}[$__range])))"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Messages Updated (count)",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "refId": "A",
          "expr": "round(sum(increase(forum_messages_updated_total{service_name=\"$application\"}[$__range])))"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Messages Deleted (count)",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "refId": "A",
          "expr": "round(sum(increase(forum_messages_deleted_total{service_name=\"$application\"}[$__range])))"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Messages Fetch (count)",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "refId": "A",
          "expr": "round(sum(increase(forum_messages_fetched_total{service_name=\"$application\"}[$__range])))"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Message Operations by Type",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "refId": "A",
          "expr": "round(sum(increase(forum_messages_created_total{service_name=\"$application\"}[$__range])))",
          "legendFormat": "create"
        },
        {
          "refId": "B",
          "expr": "round(sum(increase(forum_messages_updated_total{service_name=\"$application\"}[$__range])))",
          "legendFormat": "update"
        },
        {
          "refId": "C",
          "expr": "round(sum(increase(forum_messages_deleted_total{service_name=\"$application\"}[$__range])))",
          "legendFormat": "delete"
        },
        {
          "refId": "D",
          "expr": "round(sum(increase(forum_messages_fetched_total{service_name=\"$application\"}[$__range])))",
          "legendFormat": "fetch"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Redis Cache Hits vs Misses",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "refId": "A",
          "expr": "round(sum(increase(forum_cache_access_total{service_name=\"$application\",result=\"hit\"}[$__range]))) or vector(0)",
          "legendFormat": "hit"
        },
        {
          "refId": "B",
          "expr": "round(sum(increase(forum_cache_access_total{service_name=\"$application\",result=\"miss\"}[$__range]))) or vector(0)",
          "legendFormat": "miss"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Database Operations (Repository Invocations)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (operation, repository_method) (rate(forum_db_operations_total{service_name=\"$application\"}[5m]))",
          "legendFormat": "{{operation}} - {{repository_method}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "DB Connection Pool Activity",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "refId": "A",
          "expr": "avg(hikaricp_connections_active{service_name=\"$application\"})",
          "legendFormat": "active"
        },
        {
          "refId": "B",
          "expr": "avg(hikaricp_connections_idle{service_name=\"$application\"})",
          "legendFormat": "idle"
        },
        {
          "refId": "C",
          "expr": "avg(hikaricp_connections_pending{service_name=\"$application\"})",
          "legendFormat": "pending"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "none" }, "overrides": [] }
    }
  ]
}
